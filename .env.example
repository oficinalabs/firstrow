# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Emails de admin (separados por vírgula) — quem pode criar eventos
ADMIN_EMAILS=

# Auth (Better Auth) — gera o secret com: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Base de dados (Neon Postgres) — usa a connection string "Pooled"
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/firstrow?sslmode=require

# Pagamentos (Eupago) — ver docs/PAGAMENTOS.md
EUPAGO_ENV=sandbox
EUPAGO_API_KEY=
EUPAGO_WEBHOOK_SECRET=
# externKeys do split (backoffice Eupago) + comissão da plataforma (%)
EUPAGO_LEAGUE_EXTERNKEY=
EUPAGO_PLATFORM_EXTERNKEY=
PLATFORM_COMMISSION_PCT=10

# Vídeo (Cloudflare Stream) — ver docs/ARQUITETURA.md
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY_JWK=

# Email (Resend)
RESEND_API_KEY=

# Observabilidade (Sentry)
SENTRY_DSN=
