# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Emails de admin (separados por vírgula). BOOTSTRAP apenas: promove o PRIMEIRO
# platform_admin e deixa de ter efeito assim que exista um (ver server/authz.ts).
ADMIN_EMAILS=

# Auth (Better Auth) — gera o secret com: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Login com Google (opcional — sem estas, o botão nem é desenhado)
# Google Cloud Console → Credentials → OAuth client ID (tipo Web).
# Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base de dados (Neon Postgres) — usa a connection string "Pooled"
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/firstrow?sslmode=require

# Pagamentos (Eupago) — ver docs/PAGAMENTOS.md
EUPAGO_ENV=sandbox
EUPAGO_API_KEY=
EUPAGO_WEBHOOK_SECRET=
# externKeys do split (backoffice Eupago) + comissão da plataforma (%)
EUPAGO_LEAGUE_EXTERNKEY=
EUPAGO_PLATFORM_EXTERNKEY=
PLATFORM_COMMISSION_PCT=10

# Vídeo (Cloudflare Stream) — ver docs/ARQUITETURA.md
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY_JWK=

# Email (Resend). Com RESEND_API_KEY definida, o login passa a EXIGIR email
# confirmado (ver lib/auth.ts). O remetente TEM de pertencer a um domínio
# verificado no Resend — senão os emails de ativação falham em silêncio.
RESEND_API_KEY=
EMAIL_FROM=FirstRow <no-reply@exemplo.pt>

# Observabilidade (Sentry)
SENTRY_DSN=
