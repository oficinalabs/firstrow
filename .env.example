# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth (Better Auth) — gera o secret com: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Base de dados (Supabase Postgres) — usa o pooler (pgbouncer)
DATABASE_URL=postgresql://postgres:password@localhost:5432/firstrow

# Pagamentos (Eupago) — ver docs/PAGAMENTOS.md
EUPAGO_API_KEY=
EUPAGO_WEBHOOK_SECRET=

# Vídeo (Cloudflare Stream) — ver docs/ARQUITETURA.md
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY_JWK=

# Email (Resend)
RESEND_API_KEY=

# Observabilidade (Sentry)
SENTRY_DSN=
